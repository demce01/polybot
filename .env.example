# ─── Wallet credentials (required for live trading only) ───────────────────────
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
POLYMARKET_FUNDER_ADDRESS=0xYOUR_FUNDER_ADDRESS_HERE  # same as wallet if no proxy

# ─── Paper trading starting balance ────────────────────────────────────────────
PAPER_BALANCE=1000.0

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
